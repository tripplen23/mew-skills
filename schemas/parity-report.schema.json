{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tripplen23/mew-skills/schemas/parity-report.schema.json",
  "title": "Mew Parity Report",
  "type": "object",
  "required": [
    "run_id",
    "total_properties",
    "passed",
    "mismatches",
    "verdict",
    "results"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Format: YYYYMMDD-HHMMSS-<7char hash>"
    },
    "total_properties": {
      "type": "integer",
      "minimum": 1
    },
    "passed": {
      "type": "integer",
      "minimum": 0
    },
    "mismatches": {
      "type": "integer",
      "minimum": 0
    },
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "conditional_pass",
        "fail"
      ]
    },
    "tolerance_class": {
      "type": "string",
      "enum": [
        "exact",
        "isclose",
        "ulps",
        "custom"
      ],
      "description": "Approved numerical tolerance used for comparison"
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "property_id",
          "status"
        ],
        "properties": {
          "property_id": {
            "type": "string",
            "pattern": "^P\\d{3,}$"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "mismatch"
            ]
          },
          "old_output": {
            "type": "object",
            "description": "Executable oracle output; omitted for non-executable oracle checks"
          },
          "new_output": {
            "type": "object",
            "description": "Candidate output; omitted for non-executable oracle checks"
          },
          "normalized_equal": {
            "type": "boolean"
          },
          "classification": {
            "type": "string",
            "enum": [
              "regression",
              "tolerance_miss",
              "nondeterminism",
              "intentional_change",
              "deprecation",
              "performance_regression",
              "provenance_break",
              "reproducibility_break",
              "normalization_gap",
              "contract_gap"
            ]
          },
          "investigation": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "status": {
                  "const": "pass"
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "properties": {
                "normalized_equal": {
                  "const": true
                }
              },
              "not": {
                "required": [
                  "classification"
                ]
              }
            }
          },
          {
            "if": {
              "properties": {
                "status": {
                  "const": "mismatch"
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "required": [
                "classification",
                "investigation"
              ],
              "properties": {
                "normalized_equal": {
                  "const": false
                }
              }
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "performance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "old_p95_ms",
          "new_p95_ms",
          "regression_pct",
          "gate"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "old_p95_ms": {
            "type": "number"
          },
          "new_p95_ms": {
            "type": "number"
          },
          "regression_pct": {
            "type": "number"
          },
          "gate": {
            "type": "string",
            "enum": [
              "pass",
              "fail"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}