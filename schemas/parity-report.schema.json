{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tripplen23/mew-skills/schemas/parity-report.schema.json",
  "title": "Mew Parity Report",
  "type": "object",
  "required": [
    "run_id",
    "total_properties",
    "passed",
    "mismatches",
    "verdict"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Format: YYYYMMDD-HHMMSS-<7char hash>"
    },
    "total_properties": {
      "type": "integer"
    },
    "passed": {
      "type": "integer"
    },
    "mismatches": {
      "type": "integer"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "conditional_pass", "fail"]
    },
    "tolerance_class": {
      "type": "string",
      "enum": ["exact", "isclose", "ulps", "custom"],
      "description": "Numerical tolerance used for comparison (PEP 485 semantics for isclose)"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["property_id", "status"],
        "properties": {
          "property_id": {
            "type": "string",
            "pattern": "^P\\d{3,}$"
          },
          "status": {
            "type": "string",
            "enum": ["pass", "mismatch", "skip"]
          },
          "old_output": {
            "type": "object"
          },
          "new_output": {
            "type": "object"
          },
          "normalized_equal": {
            "type": "boolean"
          },
          "classification": {
            "type": "string",
            "enum": [
              "real_regression",
              "tolerance_miss",
              "determinism_hazard",
              "tolerated_difference",
              "deliberate_change",
              "dropped_behavior",
              "performance_regression",
              "license_provenance_break",
              "reproducibility_break",
              "intentional_change",
              "normalization_gap",
              "regression",
              "contract_gap"
            ]
          },
          "investigation": {
            "type": "string"
          }
        }
      }
    },
    "performance": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "old_p95_ms": { "type": "number" },
          "new_p95_ms": { "type": "number" },
          "regression_pct": { "type": "number" },
          "gate": { "type": "string", "enum": ["PASS", "FAIL"] }
        }
      }
    }
  },
  "additionalProperties": false
}