{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tripplen23/mew-skills/schemas/run-manifest.schema.json",
  "title": "Mew Run Manifest",
  "description": "Identity and metadata for a single Mew migration run",
  "type": "object",
  "required": [
    "run_id",
    "source_repo",
    "source_commit",
    "created_at",
    "status"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^\\d{8}-\\d{6}-[a-z0-9]{7}$",
      "description": "Format: YYYYMMDD-HHMMSS-<7char hash>"
    },
    "source_repo": {
      "type": "string",
      "description": "Repository path or URL"
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "initialized",
        "ingesting",
        "contracting",
        "planning",
        "implementing",
        "verifying",
        "complete",
        "failed",
        "aborted"
      ]
    },
    "target_language": {
      "type": "string",
      "description": "e.g., rust, go, typescript"
    },
    "skills_used": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tools": {
      "type": "object",
      "description": "Tool registry: name \u2192 version"
    }
  },
  "additionalProperties": false
}