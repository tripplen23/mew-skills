{
    "title": "Mew Run State",
    "description": "Mutable progress view for resuming a Mew run or multi-run program",
    "type": "object",
    "required": [
        "run_id",
        "request_sha256",
        "updated_at",
        "items"
    ],
    "properties": {
        "run_id": {
            "type": "string",
            "pattern": "^\\d{8}-\\d{6}-[a-z0-9]{7}$"
        },
        "request_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
        },
        "updated_at": {
            "type": "string",
            "format": "date-time"
        },
        "parent": {
            "type": "object",
            "required": [
                "run_id",
                "item_id"
            ],
            "properties": {
                "run_id": {
                    "type": "string",
                    "pattern": "^\\d{8}-\\d{6}-[a-z0-9]{7}$"
                },
                "item_id": {
                    "type": "string",
                    "pattern": "^W\\d{3,}$"
                }
            },
            "additionalProperties": false
        },
        "focus_item": {
            "type": "string",
            "pattern": "^W\\d{3,}$"
        },
        "next_action": {
            "type": "string",
            "minLength": 1
        },
        "items": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "title",
                    "status",
                    "run_refs"
                ],
                "properties": {
                    "id": {
                        "type": "string",
                        "pattern": "^W\\d{3,}$"
                    },
                    "title": {
                        "type": "string",
                        "minLength": 1
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "pending",
                            "in_progress",
                            "blocked",
                            "done",
                            "deferred",
                            "cancelled"
                        ]
                    },
                    "run_refs": {
                        "type": "array",
                        "uniqueItems": true,
                        "items": {
                            "type": "string",
                            "pattern": "^\\d{8}-\\d{6}-[a-z0-9]{7}$"
                        }
                    },
                    "contract_properties": {
                        "type": "array",
                        "uniqueItems": true,
                        "items": {
                            "type": "string",
                            "pattern": "^P\\d{3,}$"
                        }
                    },
                    "plan_units": {
                        "type": "array",
                        "uniqueItems": true,
                        "items": {
                            "type": "string",
                            "pattern": "^U\\d{3,}$"
                        }
                    },
                    "remaining_scope": {
                        "type": "array",
                        "uniqueItems": true,
                        "items": {
                            "type": "string",
                            "minLength": 1
                        }
                    }
                },
                "additionalProperties": false
            }
        },
        "open_decisions": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "blockers": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            }
        }
    },
    "dependentRequired": {
        "focus_item": [
            "next_action"
        ]
    },
    "additionalProperties": false
}