{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tripplen23/mew-skills/schemas/behavioral-contract.schema.json",
  "title": "Mew Behavioral Contract",
  "description": "Explicit list of properties a migration must preserve",
  "type": "object",
  "required": [
    "contract_id",
    "source_commit",
    "properties"
  ],
  "properties": {
    "contract_id": {
      "type": "string"
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "approved_by": {
      "type": "string"
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "properties": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "surface",
          "property",
          "preservation",
          "oracle"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^P\\d{3,}$"
          },
          "surface": {
            "type": "string",
            "enum": [
              "api",
              "cli",
              "database",
              "file",
              "event",
              "error",
              "performance",
              "other"
            ]
          },
          "path": {
            "type": "string",
            "description": "Endpoint path, command name, or resource identifier"
          },
          "property": {
            "type": "string",
            "description": "Human-readable description of the behavior"
          },
          "preservation": {
            "type": "string",
            "enum": [
              "preserve",
              "introduce",
              "intentionally-change",
              "deprecate",
              "unknown"
            ],
            "description": "Existing behavior uses preserve, intentionally-change, or deprecate; new target behavior uses introduce. Oracle kind, not this label, selects the verification method."
          },
          "oracle": {
            "type": "object",
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "executable-baseline",
                  "authorized-reference",
                  "characterization",
                  "regression",
                  "contract-spec",
                  "unresolved"
                ]
              },
              "command": {
                "type": "string",
                "description": "Executable comparison command when applicable"
              },
              "artifact": {
                "type": "string",
                "description": "Golden, trace, fixture, or captured baseline path"
              },
              "assertion": {
                "type": "string",
                "description": "Contract, characterization, or regression assertion"
              },
              "authorization": {
                "type": "string",
                "description": "Authorization evidence for an executable external reference"
              }
            },
            "additionalProperties": false
          },
          "evidence": {
            "type": "object",
            "description": "Captured inputs, outputs, and observations supporting this behavior"
          },
          "risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "preservation": {
                  "const": "unknown"
                }
              }
            },
            "then": {
              "properties": {
                "oracle": {
                  "properties": {
                    "kind": {
                      "const": "unresolved"
                    }
                  }
                }
              }
            },
            "else": {
              "properties": {
                "oracle": {
                  "properties": {
                    "kind": {
                      "not": {
                        "const": "unresolved"
                      }
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "oracle": {
                  "properties": {
                    "kind": {
                      "const": "contract-spec"
                    }
                  }
                }
              }
            },
            "then": {
              "properties": {
                "oracle": {
                  "required": [
                    "assertion"
                  ]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "oracle": {
                  "properties": {
                    "kind": {
                      "const": "authorized-reference"
                    }
                  }
                }
              }
            },
            "then": {
              "properties": {
                "oracle": {
                  "required": [
                    "command",
                    "authorization"
                  ]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "oracle": {
                  "properties": {
                    "kind": {
                      "const": "executable-baseline"
                    }
                  }
                }
              }
            },
            "then": {
              "properties": {
                "oracle": {
                  "anyOf": [
                    {
                      "required": [
                        "command"
                      ]
                    },
                    {
                      "required": [
                        "artifact"
                      ]
                    }
                  ]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "oracle": {
                  "properties": {
                    "kind": {
                      "enum": [
                        "characterization",
                        "regression"
                      ]
                    }
                  }
                }
              }
            },
            "then": {
              "properties": {
                "oracle": {
                  "anyOf": [
                    {
                      "required": [
                        "artifact"
                      ]
                    },
                    {
                      "required": [
                        "assertion"
                      ]
                    }
                  ]
                }
              }
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "intentional_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "property_ref",
          "what",
          "why",
          "risk",
          "approved"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^C\\d{3,}$"
          },
          "property_ref": {
            "type": "string",
            "pattern": "^P\\d{3,}$"
          },
          "what": {
            "type": "string"
          },
          "why": {
            "type": "string"
          },
          "risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "approved": {
            "type": "boolean"
          }
        }
      }
    },
    "normalization_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "performance_budgets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "p95_ms": {
            "type": "number"
          },
          "p99_ms": {
            "type": "number"
          },
          "peak_memory_mb": {
            "type": "number"
          }
        }
      }
    }
  },
  "dependentRequired": {
    "approved_by": [
      "approved_at"
    ],
    "approved_at": [
      "approved_by"
    ]
  },
  "additionalProperties": false
}